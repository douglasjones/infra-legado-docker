@charset "utf-8";
/* CSS Document */
BODY {
    background: #e4e4e4; 
	margin-top : 0;
	margin-right : 0;
	margin-left : 0;
	margin-bottom : 0;
}
.espcao_br {
  line-height: 40%;
}
/*TITULO*/
.titulo_div{
	background:#FFF;
	width:99%;
	margin: 0 auto;
	margin-top:5px;
	border: 0.2mm solid #CCC;}
	
.titulo_formulario_pai{
	color:#CCCCCC;
	text-align :left;
	margin-top:auto;
	font-style : normal ;
	text-decoration : none ;
	font-size : 1.3em ;
	font-family : 'LeagueGothicRegular' ;}

.titulo_formulario_filho{
	color:#006;
	text-align :left;
	margin-top:auto;
	font-style : normal ;
	text-decoration : none ;
	font-size : 1em ;
	font-family : 'LeagueGothicRegular' ;}
	
/*FORMULARIO*/	
.formulario_div{
	background:#FFF;
	width:99%;
	margin: 0 auto;
	border: 0.2mm solid #CCC;}
	
.formulario {
	color:#999;
	text-align : left ;
	margin-left: 5px
	font-style : normal ;
	text-decoration : none ;
	font-size : 12 ;
	font-family : 'Comic Sans MS, cursive' ;}

.formulario_text {
	border: 0.1mm solid #CCC;
	color: #f5f5f5f;
	height:25%;
	font-size: 8; 
	letter-spacing: 0px;
	background-color:#f5f5f5;}

	
/*BOTÃO*/
.botao_div{	
	width:99%;
	margin: 0 auto;}






	

