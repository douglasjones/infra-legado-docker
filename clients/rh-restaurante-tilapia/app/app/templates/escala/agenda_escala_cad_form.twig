                                                <input  class='form-control form-control-sm' maxlength="5" type='type' name='hr_termino_intervalo' id='hr_termino_intervalo' />
                                            </div>
                                            <div class='col-md-3' >
                                                <label for='colaboradores_pk_agenda'>Instrajornada: </label>
