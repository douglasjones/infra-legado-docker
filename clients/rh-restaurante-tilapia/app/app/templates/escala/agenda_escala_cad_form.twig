                                            </div>
                                        </div>
                                        <div class="row">
                                            <div class='col-md-4' >
                                                <label for='colaboradores_pk_agenda'>Tipo Escala:</label>
                                                <select class='form-control form-control-sm' id="tipo_escala_pk" name="tipo_escala_pk">
                                                    <option ></option>
                                                </select>
                                            </div>
                                        </div>
                                        <div class="row" id="exibir_variacao_escala" style="display: none">
                                            <div class='col-md-4' >
                                                <label for='colaboradores_pk_agenda'>Variação Escala:</label>
                                                <select class='form-control form-control-sm' id="ic_variacao_dias_escala" name="ic_variacao_dias_escala">
                                                    <option ></option>
                                                    <option value="1">Impar</option>
                                                    <option value="2">Par</option>
                                                </select>
                                            </div>
                                        </div>
                                        <br>
                                        <div class="row">
