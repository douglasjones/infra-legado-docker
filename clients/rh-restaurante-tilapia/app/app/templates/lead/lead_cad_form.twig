{% if local == 2%}
    {% set area = 'operacional' %}
{% else %}
    {% set area = 'rh' %}
{% endif %}
{% extends "theme/base.twig" %}
{% block JSfiles %}
    {{ parent() }}
    <script src="/assets/plugins/jquery/js/jquery.datatables1.10.19.js"></script>
    <script src="/assets/plugins/jquery/js/dataTables.bootstrap4.min.js"></script>
    <script src="/assets/plugins/bootstrap-wizard/bootstrap.wizard.js" type="text/javascript"></script>
    <script src="/assets/plugins/daterangepicker/daterangepicker.js?v=14"></script>
    <script src="//cdnjs.cloudflare.com/ajax/libs/select2/4.0.0/js/select2.min.js"></script>
    <script src="{{ base_url() }}/assets/plugins/datepicker/js/bootstrap-datepicker.min.js"></script>
    <script src="{{ base_url() }}/assets/plugins/daterangepicker/daterangepicker.js"></script>
    <script src="{{ base_url() }}/assets/plugins/datepicker/locales/bootstrap-datepicker.pt-BR.min.js" charset="UTF-8"></script>
    <script src="/assets/js/local/lead_cad_form.js?v=14"></script>
{% endblock %}
{% block title %}
    Lead's
{% endblock %}
{% block CSSfiles %}
    {{ parent() }}
    <link href="//cdnjs.cloudflare.com/ajax/libs/select2/4.0.0/css/select2.min.css" rel="stylesheet" />
    <link href='{{ base_url() }}/assets/plugins/datepicker/css/bootstrap-datepicker.min.css' rel='stylesheet'>
    <link href='{{ base_url() }}/assets/plugins/bootstrap/css/dataTables.bootstrap4.min.css' rel='stylesheet' type='text/css'>
    <link href="/assets/plugins/bootstrap-wizard/bootstrap.wizard.css" rel="stylesheet" type="text/css">
    <link href='/assets/plugins/daterangepicker/daterangepicker.css?v={{ JSversion }}' rel='stylesheet' type='text/css'>

{% endblock %}
{% block content %}
    <BR>
    <BR>
    <BR>
    <main class="content_wrapper">
        <div class="container">
            <div class="container col-md-12">
                <div class="row">
                    <div class="col-md-8">
                        &nbsp;
                    </div>
                </div>
                <div class="row ">
                    <div>
                        <div class="col-lg" style="max-width:1245px;margin-left: auto;margin-right: auto;background-color: #F7F7F7;">
                            <div class="shadow-lg bg-white rounded mb-4" style="padding: 15px;">
                                <div class='row'>
                                    <div class="card-title col-sm-4">
                                        <h5 style= "color:#FF5403"  >Lead</h5>
                                    </div>
                                    <div class='col-sm-8' align="Right" >
                                        <button type="button" class="btn btn-secondary btn-sm" id="cmdCancelar">Voltar</button>&nbsp;
                                        <button type="button" class="btn btn-primary btn-sm" id="cmdEnviarTudo">Salvar</button>
                                    </div>
                                </div>
                                <div class="card-body">
                                    <input type="hidden" id="local" value="{{ local }}">
                                    <input type="hidden" id="leads_pk" value="{{ pk }}">
                                    <input type="hidden" id="usuario_logado" value="{{ session['session_user']['par2'] }}">
                                    <input type="hidden" id="dt_atual" value="{{"now"|date("d/m/Y")  }}">
                                    <div class="row">
                                        <div class="col-md-12">
                                            <ul class="nav nav-pills nav-fill" id="myTab" role="tablist">
                                                <li class="nav-item">
                                                    <a class="nav-link active"  id="dados-tab" data-toggle="tab" href="#dados" role="tab" aria-controls="dados" >Dados Cadastrais</a>
                                                </li>
                                                <li class="nav-item">
                                                    <a class="nav-link" id="funcao-tab" data-toggle="tab" href="#funcao" role="tab" aria-controls="funcao" >Funções</a>
                                                </li>
                                                <li class="nav-item" style="display: none" id="exibir_escala">
                                                    <a class="nav-link" id="escala-tab" data-toggle="tab" href="#escala" role="tab" aria-controls="escala"  >Escalas</a>
                                                </li>
                                                <!--li class="nav-item">
                                                    <a class="nav-link" id="ocorrencia-tab" data-toggle="tab" href="#ocorrencia" role="tab" aria-controls="ocorrencia" >Ocorrências</a>
                                                </li-->
                                                <li class="nav-item">
                                                    <a class="nav-link" id="documento-tab" data-toggle="tab" href="#documento" role="tab" aria-controls="documento" >Documentos</a>
                                                </li>

                                            </ul>
                                        </div>
                                    </div>
                                    <div class="tab-content" id="myTabContent">
                                        <div class="tab-pane fade show active" id="dados" role="tabpanel" aria-labelledby="dados-tab">
                                            <div class="row">
                                                <div class="col-md-11">
                                                    <div class='col-md-2'>
                                                        &nbsp; &nbsp; &nbsp;
                                                    </div>
                                                    <h4>Dados Cadastrais</h4>
                                                    <hr style='height:1px; border:none; color:#14074F; background-color:#14074F; margin-top: 0px; margin-bottom: 0px;'>
                                                    <div class='col-md-2'>
                                                        &nbsp;
                                                    </div>
                                                </div>
                                            </div>
                                            <div class='row'>
                                                <div class='col-md-4'>
                                                    <label>Tipo Posto de Trabalho:</label>
                                                    <select id="tipo_grupos_lead_pk" class='form-control form-control-sm ' name="tipo_grupos_lead_pk">
                                                        <option ></option>
                                                        <option value="1" >Escritório</option>
                                                        <option value="2" >Estacionamento</option>
                                                        <option value="3" >Fábrica</option>
                                                        <option value="4" >Loja</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class='row' id="alert_tipo_posto" style="display:none">
                                                <div class='col-md-8'>
                                                    <strong style="color: red">Por favor, informe Tipo Posto de Trabalho</strong>
                                                </div>
                                            </div>
                                            <div class='row'>
                                                <div class='col-md-4'>
                                                    <label for='ds_uf'>Grupos:</label>
                                                    <select id="grupos_leads_pk" class='form-control form-control-md'  name="grupos_leads_pk">
                                                        <option ></option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class='row' id="alert_grupo" style="display:none">
                                                <div class='col-md-8'>
                                                    <strong style="color: red">Por favor, informe Grupos</strong>
                                                </div>
                                            </div>

                                            <div class='row'>
                                                <div class='col-md-6'>
                                                    <label>Lead - Identificação do Posto de Trabalho</label>
                                                    <input type="text" id="ds_lead" class='form-control form-control-sm' name="ds_lead" maxlength="100" placeholder=" " />
                                                </div>
                                            </div>
                                            <div class='row'>
                                                <div class='col-md-6'>
                                                    <label>Apelido Posto Trabalho</label>
                                                    <input type="text" id="ds_lead_apelido" class='form-control form-control-sm' name="ds_lead_apelido" maxlength="100" placeholder=" " />
                                                </div>
                                            </div>
                                            <div class='row' id="alert_ds_lead" style="display:none">
                                                <div class='col-md-8'>
                                                    <strong style="color: red">Por favor, informe Lead</strong>
                                                </div>
                                            </div>
                                            <div class='row'>
                                                <div class='col-md-2'>
                                                    <label for='cpf_cnpj'>CPF/CNPJ:</label>
                                                    <input type='text' class='form-control form-control-sm' id='ds_cpf_cnpj' name='ds_cpf_cnpj' >
                                                </div>
                                                <div class='col-md-2'>
                                                    <br>
                                                    <button type="button" class="btn btn-primary btn-sm" id="cmdConsultarCNPJ"  onclick="validarCnpj(ds_cpf_cnpj.value)" >Consultar CNPJ</button>
                                                </div>
                                            </div>
                                            <div class='row'>
                                                <div class='col-md-8'>
                                                    <label>Razão Social</label>
                                                    <input type="text" id="ds_razao_social" class='form-control form-control-sm' name="ds_razao_social" maxlength="100" placeholder=" "/>
                                                </div>
                                            </div>
                                            <!----------------------ALERT------------------>

                                            <div class='row'>
                                                <div class='col-md-2'>
                                                    <label>Telefone:</label>
                                                    <input type="text" id="ds_tel_fixo" class='form-control form-control-sm' name="ds_tel_fixo"  placeholder=" " />
                                                </div>
                                                <div class='col-md-2'>
                                                    <label>Celular:</label>
                                                    <input type="text" id="ds_tel_fixo1" class='form-control form-control-sm' name="ds_tel_fixo1"  placeholder=" " />
                                                </div>
                                            </div>
                                            <div class="row">
                                                <p>
                                                <div class="col-md-11">
                                                    <h4>Endereço</h4>
                                                    <hr style='height:1px; border:none; color:#14074F; background-color:#14074F; margin-top: 0px; margin-bottom: 0px;'>
                                                </div>
                                            </div>
                                            <div class='row'>
                                                <div class='col-md-3'>
                                                    <label>CEP</label>
                                                    <input type="text" id="ds_cep" class='form-control form-control-sm' name="ds_cep" maxlength="9" placeholder=" " requered/>
                                                </div>
                                            </div>
                                            <!----------------------ALERT------------------>
                                            <div class='row' id="alert_ds_cep" style="display:none">
                                                <div class='col-md-3'>
                                                    <strong style="color: red">Por favor, informe CEP</strong>
                                                </div>
                                            </div>
                                            <div class='row'>
                                                <div class='col-md-8'>
                                                    <label>Endereço</label>
                                                    <input type="text" id="ds_endereco" class='form-control form-control-sm' name="ds_endereco" maxlength="100" placeholder=" " requered/>
                                                </div>
                                            </div>
                                            <!----------------------ALERT------------------>
                                            <div class='row' id="alert_ds_endereco" style="display:none">
                                                <div class='col-md-2'>
                                                    <strong style="color: red">Por favor, informe Endereço</strong>
                                                </div>
                                            </div>
                                            <div class='row'>
                                                <div class='col-md-2'>
                                                    <label>Nr</label>
                                                    <input type="text" id="ds_numero" class='form-control form-control-sm' name="ds_numero" maxlength="10" placeholder=" " requered="true"/>
                                                </div>
                                                <div class='col-md-3'>
                                                    <label>Complemento</label>
                                                    <input type="text" id="ds_complemento" class='form-control form-control-sm' name="ds_complemento" maxlength="10" placeholder=" "/>
                                                </div>
                                            </div>
                                            <!----------------------ALERT------------------>
                                            <div class='row' id="alert_ds_numero" style="display:none">
                                                <div class='col-md-2'>
                                                    <strong style="color: red">Por favor, informe Numero</strong>
                                                </div>
                                            </div>
                                            <div class='row'>
                                                <div class='col-md-3'>
                                                    <label>Bairro</label>
                                                    <input type="text" id="ds_bairro" class='form-control form-control-sm' name="ds_bairro" maxlength="45" placeholder=" " requered/>
                                                </div>
                                                <div class='col-md-3'>
                                                    <label>Cidade</label>
                                                    <input type="text" id="ds_cidade" class='form-control form-control-sm' name="ds_cidade" maxlength="45" placeholder=" " requered/>
                                                </div>
                                                <div class='col-md-2'>
                                                    <label for='ds_uf'>UF:&nbsp;</label>
                                                    <select class='form-control form-control-sm'  id='ds_uf' name='ds_uf'>
                                                        <option></option>
                                                        <option>AC</option>
                                                        <option>AL</option>
                                                        <option>AP</option>
                                                        <option>AM</option>
                                                        <option>BA</option>
                                                        <option>CE</option>
                                                        <option>DF</option>
                                                        <option>ES</option>
                                                        <option>GO</option>
                                                        <option>MA</option>
                                                        <option>MT</option>
                                                        <option>MS</option>
                                                        <option>MG</option>
                                                        <option>PA</option>
                                                        <option>PB</option>
                                                        <option>PR</option>
                                                        <option>PE</option>
                                                        <option>PI</option>
                                                        <option>RJ</option>
                                                        <option>RN</option>
                                                        <option>RS</option>
                                                        <option>RO</option>
                                                        <option>RR</option>
                                                        <option>SC</option>
                                                        <option>SP</option>
                                                        <option>SE</option>
                                                        <option>TO</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <!----------------------ALERT------------------>
                                            <div class='row' id="alert_cidade_bairro" style="display:none">
                                                <div class='col-md-3' id="alert_ds_bairro" style="display:none">
                                                    <strong style="color: red">Por favor, informe Bairro</strong>
                                                </div>
                                                <div class='col-md-2'>
                                                    &nbsp;
                                                </div>
                                                <div class='col-md-3' id="alert_ds_cidade" style="display:none">
                                                    <strong style="color: red">Por favor, informe Cidade</strong>
                                                </div>
                                                <div class='col-md-2'>
                                                    &nbsp;
                                                </div>
                                                <div class='col-md-3' id="alert_ds_uf" style="display:none">
                                                    <strong style="color: red">Por favor, selecione UF</strong>
                                                </div>
                                            </div>
                                            <div class='row'>
                                                <div class='col-md-2'>
                                                    <label for='supervisores_pk'>Supervisor:&nbsp;</label>
                                                    <select class='form-control form-control-sm'  id='supervisor_pk' name='supervisor_pk' />
                                                    <option></option>
                                                    </select>
                                                </div>
                                                <div class='col-md-2'>
                                                    <label for='supervisores2_pk'>Supervisor 2:&nbsp;</label>
                                                    <select class='form-control form-control-sm'  id='supervisor2_pk' name='supervisor2_pk' />
                                                    <option></option>
                                                    </select>
                                                </div>

                                            </div>
                                            <div class='row'>
                                                <div class='col-md-2'>
                                                    <label for='ic_cliente'>Status:&nbsp;</label>
                                                    <select class='form-control form-control-sm'  id='ic_status' name='ic_status' requered/>
                                                    <option></option>
                                                    <option value='1'>Sim</option>
                                                    <option value='2'>Não</option>
                                                    </select>
                                                </div>
                                                <div class='col-md-2'>
                                                    <label for='ic_cliente'>Data Ativação:&nbsp;</label>
                                                    <input type='text' class='form-control form-control-sm'  id='dt_ativacao' name='dt_ativacao' maxlength='10'/>
                                                </div>
                                            </div>
                                            <!----------------------ALERT------------------>
                                            <div class='row' id="alert_ic_cliente" style="display:none">
                                                <div class='col-md-2' >
                                                    <strong style="color: red">Por favor, Selecione Status</strong>
                                                </div>
                                            </div>
                                            <p>
                                        </div>
                                        <div class="tab-pane fade" id="funcao" role="tabpanel" aria-labelledby="funcao-tab">
                                            <br>
                                            <div class='row'>
                                                <div class='col-md-12'>
                                                    <button type="button" id="btn_modal_funcao" class="btn btn-primary btn-sm" >Incluir Função</button>
                                                </div>
                                            </div>
                                            <br>
                                            <div class="row">
                                                <div class="col-md-12">
                                                    <table class="table table-striped table-bordered nowrap " id="tblFuncao">
                                                        <thead >
                                                        <tr>
                                                            <th>Código</th>
                                                            <th>Função</th>
                                                            <th>Data Cadastro</th>
                                                            <th>Usuário Cadastro</th>
                                                            <th>Status</th>
                                                            <th>Ação</th>
                                                        </tr>
                                                        </thead>
                                                        <tbody>
                                                        </tbody>
                                                    </table>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="tab-pane fade" id="escala" role="tabpanel" aria-labelledby="escala-tab">
                                            <br>
                                            <div class='row'>
                                                <div class='col-md-12'>
                                                    <button type="button" id="btn_modal_escala" class="btn btn-primary btn-sm" >Incluir Escala</button>
                                                </div>
                                            </div>
                                            <br>
                                            <div class="row">
                                                <div class="col-md-12">
                                                    <table class="table table-striped table-bordered nowrap " id="tblEscala">
                                                        <thead >
                                                        <tr>
                                                            <th>Código</th>
                                                            <th>Colaborador</th>
                                                            <th>Posto de Trabalho</th>
                                                            <th>Função</th>
                                                            <th>Escala</th>
                                                            <th>Ação</th>
                                                        </tr>
                                                        </thead>
                                                        <tbody>
                                                        </tbody>
                                                    </table>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="tab-pane fade" id="ocorrencia" role="tabpanel" aria-labelledby="ocorrencia-tab">
                                            <br>
                                            <div class='row'>
                                                <div class='col-md-12'>
                                                    <button type="button" id="btn_modal_ocorrencia" class="btn btn-primary btn-sm" >Incluir Ocorrência</button>
                                                </div>
                                            </div>
                                            <br>
                                        </div>
                                        <div class="tab-pane fade" id="documento" role="tabpanel" aria-labelledby="documento-tab">
                                            <br>
                                            <div class='row'>
                                                <div class='col-md-12'>
                                                    <button type="button" id="cmdIncluirDocumento" class="btn btn-primary btn-sm" >Incluir Documento</button>
                                                </div>
                                            </div>
                                            <br>
                                            <div class="col-md-12">
                                                <table class="table table-striped table-bordered nowrap" style="width:100%" id="tblDocumentos">
                                                    <thead>
                                                    <tr>
                                                        <th>Código</th>
                                                        <th>Documento</th>
                                                        <th>Ação</th>
                                                    </tr>
                                                    </thead>
                                                    <tbody>
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                        <div class="col-md-12" align="Right">
                                            <hr style='height:1px; border:none; color:#14074F; background-color:#14074F; margin-top: 0px; margin-bottom: 0px;'>
                                            <br>
                                            <button type="button" class="btn btn-secondary btn-sm" id="cmdCancelar2">Voltar</button>
                                            &nbsp;
                                            <button type="button" class="btn btn-primary btn-sm" id="cmdEnviarTudo2">Salvar</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
    <!-- Inicio janeja modal para edicao do registro -->
    <div class="modal fade bd-example-modal-lg" id="janela_funcao" >
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="janela_contatosLabel">Nova Função</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close" onclick="fecharModalFuncao()">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <input type='hidden' class='form-control form-control-sm'  id='acao' name='acao'>
                    <input type='hidden' class='form-control form-control-sm'  id='funcao_pk' name='funcao_pk'>

                    <div class="row">
                        <div class='col-md-5'>
                            <label for='cargos_pk'>Função: </label>
                            <select class='form-control form-control-sm'  id='cargos_pk' name='cargos_pk'>
                                <option></option>
                            </select>
                        </div>
                        <div class='col-md-5'>
                            <label for='cargos_pk'>Status: </label>
                            <select class='form-control form-control-sm'  id='ic_status_funcao' name='ic_status_funcao'>
                                <option value="1">Ativo</option>
                                <option value="2">Inativo</option>
                            </select>
                        </div>
                    </div>
                    <br>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary btn-sm" data-dismiss="modal" onclick="fecharModalFuncao()">Fechar</button>
                        <button type="button" class="btn btn-primary btn-sm" id="cmdEnviarFuncao"  name="cmdEnviarFuncao">Salvar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!------ESCALA------>
    <div class="modal fade bd-example-modal-lg" id="janela_escala" >
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="janela_contatosLabel">Nova Escala</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close" onclick="fecharModalEscala()">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <input type='hidden' class='form-control form-control-sm'  id='acaoAgenda' name='acaoAgenda'>
                    <input type='hidden' class='form-control form-control-sm'  id='escala_agenda_pk' name='escala_agenda_pk'>

                    <div class='row'>
                        <div class='col-md-4'>
                            <label for='cargos_pk'>Função: </label>
                            <select class='form-control form-control-sm'  id='escala_cargos_pk' name='escala_cargos_pk'>
                                <option></option>
                            </select>
                        </div>
                    </div>
                    <div class='row'>
                        <div class='col-md-4'>
                            <label for='ds_uf'>Colaborador:</label>
                            <select id="escala_colaborador_pk" class='form-control form-control-md'  name="escala_colaborador_pk">
                                <option ></option>
                            </select>
                        </div>
                    </div>
                    <div class='row'>
                        <div class='col-md-4'>
                            <label for='dt_inicio_agenda'>Data Início da Escala: </label>
                            <input type='text' class='form-control form-control-sm' maxlength="10"  id='dt_inicio_agenda' name='dt_inicio_agenda'>
                        </div>
                        <div class='col-md-4'>
                            <label for='dt_fim_agenda'>Data Fim Termino do Contrato: </label>
                            <input type='text' class='form-control form-control-sm' maxlength="10"  id='dt_fim_agenda' name='dt_fim_agenda'>
                        </div>
                    </div>
                    <div id="exibir_data_cancelamento" style="display:none">
                        <h6>Cancelar Escala</h6>
                        <hr style='height:1px; border:none; color:#14074F; background-color:#14074F; margin-top: 0px; margin-bottom: 0px;'>
                        <div class="row">
                            <div class='col-md-4'>
                                <label for='cargos_pk'>Data Cancelamento: </label>
                                <input class='form-control form-control-sm'  id='dt_cancelamento_agenda_escala' name='dt_cancelamento_agenda_escala' />
                            </div>
                        </div>
                        <div class="row">
                            <div class='col-md-6'>
                                <label for='cargos_pk'>Motivo Cancelamento: </label>
                                <textarea class='form-control form-control-sm'  id='ds_motivo_cancelamento' name='ds_motivo_cancelamento' /></textarea>
                            </div>
                        </div>
                        <br>
                    </div>
                    <div class="row">
                        <div class='col-md-3' >
                            <label for='colaboradores_pk_agenda'>Turno: </label>
                            <select class='form-control form-control-sm'  id='turnos_pk' name='turnos_pk' />
                                <option></option>
                                <option value="4">Dia Inteiro</option>
                                <option value="1">Manhã</option>
                                <option value="2">Tarde</option>
