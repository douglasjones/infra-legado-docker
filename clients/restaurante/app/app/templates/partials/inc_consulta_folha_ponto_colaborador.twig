<script>
    function fcImprimirRelogio() {
        var printContents = document.getElementById("printableAreaRelogio").innerHTML;
        
        var printWindow = window.open('', '', 'height=800,width=600');
        printWindow.document.write('<html><head><title>'+$("#colaborador_consulta_folha_pk option:selected").text()+' - '+$("#leads_consulta_folha_pk option:selected").text()+' - '+$("#ic_consulta_folha_mes option:selected").text()+' / '+$("#ic_consulta_folha_ano option:selected").text()+'</title>');
        printWindow.document.write('<style>@page { size: A4; margin: 10mm; } #printableAreaRelogio { width: 100%; font-size: 12pt; overflow: hidden; } </style>');
        printWindow.document.write('</head><body>');
        printWindow.document.write(printContents);
        printWindow.document.write('</body></html>');
        printWindow.document.close();
        printWindow.print();
    }
</script>
<style>
    @media print {
        #noprint{
            display:none;
        }
        /* Define o tamanho da página para A4 */
        @page {
            size: A4;
            margin: 10mm; /* Ajuste as margens conforme necessário */
        }

        /* Ajusta o conteúdo para caber na página */
        #printableAreaRelogio {
            width: 100%;
            font-size: 12pt; /* Ajuste o tamanho da fonte conforme necessário */
            overflow: hidden;
            page-break-inside: avoid;
        }

        /* Reduz imagens ou outros elementos grandes */
        #printableAreaRelogio img {
            max-width: 100%; /* Garante que as imagens não ultrapassem a largura da página */
            height: auto;
        }

        /* Estilos adicionais para garantir que a impressão seja adequada */
        .row {
            display: flex;
            flex-wrap: wrap;
        }
        
        .col-md-4, .col-md-12 {
            width: 100%;
            margin-bottom: 10px;
        }

        /* Remove o botão Fechar e Gerar PDF durante a impressão */
        .modal-header div {
            display: none;
        }
    }
</style>



