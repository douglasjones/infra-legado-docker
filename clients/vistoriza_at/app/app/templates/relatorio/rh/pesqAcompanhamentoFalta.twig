{% set area = 'relatorios' %}
{% extends "theme/base.twig" %}
{% block JSfiles %}
    {{ parent() }}
    <script src="/assets/plugins/jquery/js/jquery.datatables1.10.19.js"></script>
    <script src="/assets/plugins/jquery/js/dataTables.bootstrap4.min.js"></script>
    <script src="/assets/plugins/bootstrap-wizard/bootstrap.wizard.js" type="text/javascript"></script>
    <script src="/assets/plugins/daterangepicker/daterangepicker.js?v=14"></script>
    <script src="//cdnjs.cloudflare.com/ajax/libs/select2/4.0.0/js/select2.min.js"></script>
    <script src="{{ base_url() }}/assets/plugins/datepicker/js/bootstrap-datepicker.min.js"></script>
    <script src="{{ base_url() }}/assets/plugins/daterangepicker/daterangepicker.js"></script>
    <script src="{{ base_url() }}/assets/plugins/datepicker/locales/bootstrap-datepicker.pt-BR.min.js" charset="UTF-8"></script>
    <script src="/assets/js/local/pesq_acompanhamento_falta.js?v=15"></script>
{% endblock %}
{% block title %}
     Relatório Acompanhamento de Faltas
{% endblock %}
{% block CSSfiles %}
    {{ parent() }}
    <link href="//cdnjs.cloudflare.com/ajax/libs/select2/4.0.0/css/select2.min.css" rel="stylesheet" />
    <link href='{{ base_url() }}/assets/plugins/datepicker/css/bootstrap-datepicker.min.css' rel='stylesheet'>
    <link href='{{ base_url() }}/assets/plugins/bootstrap/css/dataTables.bootstrap4.min.css' rel='stylesheet' type='text/css'>
    <link href="/assets/plugins/bootstrap-wizard/bootstrap.wizard.css" rel="stylesheet" type="text/css">
    <link href='/assets/plugins/daterangepicker/daterangepicker.css?v={{ JSversion }}' rel='stylesheet' type='text/css'>

{% endblock %}
{% block content %}
    <BR>
    <br>
    <br>
    <main class="content_wrapper">
        <div class="container">
            <div class="container col-md-12">
                <div class="row">
                    <div class="col-md-8">
                        &nbsp;
                    </div>
                </div>
                <div class="row ">
                    <div  tabindex="-1" role="dialog" aria-labelledby="modal-set-ramalLabel" >
                        <div class="col-lg" style="max-width:1245px;margin-left: auto;margin-right: auto;background-color: #F7F7F7;">
                            <div class="shadow-lg bg-white rounded mb-4" style="padding: 15px;background-color: #F7F7F7">
                                <div class="card-header" style="background-color: #F7F7F7">
                                    <div class="card-title col-sm-5">
                                        <h6 style= "color:#FF5403">Relatório Acompanhamento de Falta</h6>
                                    </div>
                                    <div class='col-sm-7' align="Right">
                                        <button type="button" class="btn btn-secondary btn-sm" id="cmdCancelar">Voltar</button>
                                        <button type="button" class="btn btn-primary btn-sm" id="cmdEnviar">Gerar Relatório</button>
                                    </div>
                                </div>
                                <div class="card-body">
                                    <div class='row'>
                                        <input type="hidden" id="agenda_consulta_folha_colaborador_pk">
                                        <div class='col-md-4'>
                                        </div>
                                        <div class='col-md-4'>
                                            <label for="ds_colaborador">Posto de Trabalho:&nbsp;</label>
                                            <div class="noprint">
                                                <select class="form-control form-control-sm chzn-select noprint" id="leads_pk" >
                                                    <option></option>
                                                </select>
                                            </div>
                                            <span id="text-posto"></span>
                                        </div>
                                    </div>
                                    <div class='row'>
                                        <div class='col-md-4'>
                                        </div>
                                        <div class='col-md-4'>
                                            <label for="ds_colaborador">Colaborador:&nbsp;</label>
                                            <div class="noprint">
                                                <select class="form-control form-control-sm chzn-select" id="colaborador_pk" >
                                                    <option></option>
                                                </select>
                                            </div>
                                        </div>
                                            <span id="text-colaborador"></span>
                                    </div>
                                    <div class='row'>
                                        <div class='col-md-4'>
                                        </div>
                                        <div class='col-md-4'>
                                            <label for="ds_colaborador">Mês:&nbsp;</label>
                                            <div class="noprint">
                                                <select class="form-control form-control-sm chzn-select" id="ic_mes" >
                                                    <option value="01">Janeiro</option>
                                                    <option value="02">Fevereiro</option>
                                                    <option value="03">Março</option>
                                                    <option value="04">Abril</option>
                                                    <option value="05">Maio</option>
                                                    <option value="06">Junho</option>
                                                    <option value="07">Julho</option>
                                                    <option value="08">Agosto</option>
                                                    <option value="09">Setembro</option>
                                                    <option value="10">Outubro</option>
                                                    <option value="11">Novembro</option>
                                                    <option value="12">Dezembro</option>
                                                </select>
                                            </div>
                                            
                                            <span id="text-mes"></span>
                                        </div>
                                    </div>
                                    <div class='row'>
                                        <div class='col-md-4'>
                                        </div>
                                        <div class='col-md-4'>
                                            <label for="ds_colaborador">Ano:&nbsp;</label>
                                            <div class="noprint">
                                                <select class="form-control form-control-sm chzn-select" id="ic_ano" name="ic_ano">
                                                    <option></option>
                                                </select>
                                            </div>
                                            <span id="text-ano"></span>
                                        </div>
                                    </div>
                                    <div class='row'>
                                        <div class='col-md-4'>
                                        </div>
                                        <div class='col-md-4'>
                                            <label>Tipo Apontamento:&nbsp;</label>
                                            <div class="noprint tipo-apontamento-checks">
                                                <div class="form-check">
                                                    <input class="form-check-input tipo-apontamento-checkbox" type="checkbox" value="2" id="tipo_apontamento_2">
                                                    <label class="form-check-label" for="tipo_apontamento_2">Falta</label>
                                                </div>
                                                <div class="form-check">
                                                    <input class="form-check-input tipo-apontamento-checkbox" type="checkbox" value="11" id="tipo_apontamento_11">
                                                    <label class="form-check-label" for="tipo_apontamento_11">Abonada</label>
                                                </div>
                                                <div class="form-check">
                                                    <input class="form-check-input tipo-apontamento-checkbox" type="checkbox" value="16" id="tipo_apontamento_16">
                                                    <label class="form-check-label" for="tipo_apontamento_16">Atestado</label>
                                                </div>
                                                <div class="form-check">
                                                    <input class="form-check-input tipo-apontamento-checkbox" type="checkbox" value="18" id="tipo_apontamento_18">
                                                    <label class="form-check-label" for="tipo_apontamento_18">Declaração da defesa civil</label>
                                                </div>
                                                <div class="form-check">
                                                    <input class="form-check-input tipo-apontamento-checkbox" type="checkbox" value="28" id="tipo_apontamento_28">
                                                    <label class="form-check-label" for="tipo_apontamento_28">Apoio Operacional</label>
                                                </div>
                                                <div class="form-check">
                                                    <input class="form-check-input tipo-apontamento-checkbox" type="checkbox" value="29" id="tipo_apontamento_29">
                                                    <label class="form-check-label" for="tipo_apontamento_29">Atestado por acompanhar filho ate 5 anos</label>
                                                </div>
                                                <div class="form-check">
                                                    <input class="form-check-input tipo-apontamento-checkbox" type="checkbox" value="30" id="tipo_apontamento_30">
                                                    <label class="form-check-label" for="tipo_apontamento_30">Atestado por serviço Justiça Eleitoral</label>
                                                </div>
                                                <div class="form-check">
                                                    <input class="form-check-input tipo-apontamento-checkbox" type="checkbox" value="37" id="tipo_apontamento_37">
                                                    <label class="form-check-label" for="tipo_apontamento_37">Atestado de horas</label>
                                                </div>
                                                <div class="form-check">
                                                    <input class="form-check-input tipo-apontamento-checkbox" type="checkbox" value="31" id="tipo_apontamento_31">
                                                    <label class="form-check-label" for="tipo_apontamento_31">Doação de sangue</label>
                                                </div>
                                                <div class="form-check">
                                                    <input class="form-check-input tipo-apontamento-checkbox" type="checkbox" value="32" id="tipo_apontamento_32">
                                                    <label class="form-check-label" for="tipo_apontamento_32">Atraso</label>
                                                </div>
                                                <div class="form-check">
                                                    <input class="form-check-input tipo-apontamento-checkbox" type="checkbox" value="33" id="tipo_apontamento_33">
                                                    <label class="form-check-label" for="tipo_apontamento_33">Declaração de horas abonar</label>
                                                </div>
                                                <div class="form-check">
                                                    <input class="form-check-input tipo-apontamento-checkbox" type="checkbox" value="34" id="tipo_apontamento_34">
                                                    <label class="form-check-label" for="tipo_apontamento_34">Sem Justificativa</label>
                                                </div>
                                                <div class="form-check">
                                                    <input class="form-check-input tipo-apontamento-checkbox" type="checkbox" value="35" id="tipo_apontamento_35">
                                                    <label class="form-check-label" for="tipo_apontamento_35">Reciclagem</label>
                                                </div>
                                                <div class="form-check">
                                                    <input class="form-check-input tipo-apontamento-checkbox" type="checkbox" value="36" id="tipo_apontamento_36">
                                                    <label class="form-check-label" for="tipo_apontamento_36">Audiência</label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>   
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
{% endblock %}
