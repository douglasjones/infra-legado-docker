{% extends "theme/base.login.twig" %}
{% block JSfiles %}
    {{ parent() }}
    <script src="/assets/plugins/jquery/js/jquery.datatables1.10.19.js"></script>
    <script src="/assets/plugins/jquery/js/dataTables.bootstrap4.min.js"></script>
    <script src="/assets/plugins/bootstrap-wizard/bootstrap.wizard.js" type="text/javascript"></script>
    <script src="/assets/plugins/daterangepicker/daterangepicker.js?v=14"></script>
    <script src="//cdnjs.cloudflare.com/ajax/libs/select2/4.0.0/js/select2.min.js"></script>
    <script src="{{ base_url() }}/assets/plugins/datepicker/js/bootstrap-datepicker.min.js"></script>
    <script src="{{ base_url() }}/assets/plugins/daterangepicker/daterangepicker.js"></script>
    <script src="{{ base_url() }}/assets/plugins/datepicker/locales/bootstrap-datepicker.pt-BR.min.js" charset="UTF-8"></script>
    <script src="/assets/js/local/area_colaborador.js?v=14"></script>
    <!-- CUSTOM JS -->
    <script src="/assets/js/global/utils.js"></script>
    <script src="/assets/js/global/bestflow.js"></script>
{% endblock %}
{% block title %}
    Aréa do Colaborador
{% endblock %}
{% block CSSfiles %}
    {{ parent() }}
    <script src="/assets/js/global/utils.js"></script>
    <script src="/assets/js/global/bestflow.js?v={{ config.VERSION_ID }}"></script>
    <script src="/assets/js/local/supervisor.js?v={{ config.VERSION_ID }}"></script>
    <!-- Inclua o jQuery primeiro -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <!-- Depois, inclua o jQuery Mask Plugin -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.min.js"></script>
        
    <script>
        $(".mask-cpf").mask("000.000.000-00", { reverse: true });

        // Força a aplicação da máscara no celular
        $(".mask-cpf").on("input keyup", function () {
            $(this).mask("000.000.000-00", { reverse: true });
        });

        $(".mask-cpf").on("input propertychange paste", function () {
            $(this).mask("000.000.000-00", { reverse: true });
        });
    
    </script>
{% endblock %}
{% block content %}
    <main class="content_wrapper">
        <div class="container">
            <div class="container col-md-12">
                <div class="row">
                    <div class="col-md-8">
                        &nbsp;
                    </div>
                </div>
                <div class="row ">
                    <div  tabindex="-1" role="dialog" aria-labelledby="modal-set-ramalLabel" >
                        <div class="col-lg" style="max-width:1245px;margin-left: auto;margin-right: auto;background-color: #F7F7F7;">
                            <div class="shadow-lg bg-white rounded mb-12" style="padding: 15px;background-color: #F7F7F7">
                                <div class="card-body" style="text-align: center">
                                    <div class='row'>
                                        <div class='col-md-2'>
                                        </div>
                                        <div class='col-md-8'>
                                            <img width="100px" src="https://server.gpros.com.br/comercial/logos/logoOficial.png" >
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-md-2">
                                            &nbsp;
                                        </div>
                                        <div class="col-md-8" >
                                            <h5 style="color:#14074f ">Seja Bem Vindo !<br> Ao Seu App de Ponto</h5>
                                        </div>
                                    </div>
                                    <div class='row'>
                                        <div class='col-md-2'>
                                        </div>
                                        <div class='col-md-8'>
                                            <img alt="" style="width: 150px;" src="/assets/img/registroPonto.png"><br>
                                            <span style="font-size: 12px;color: #14074f;"><b>Caso ja tenha se registrado, Basta Clicar em "Registrar Ponto". Para fazer um Novo Lancamento de Horas.</b></span><br><br><br>
                                            
                                        </div>
                                    </div>
                                    <div class='row'>
                                        <div class='col-md-2'>
                                        </div>
                                        <div class='col-md-8'>
                                        <a href="/area_colaborador/receptivoRegistrarPontoPorPin">
                                            <button style="width: 230px;background-color: blue;color: white" type="button" class="btn btn-outline-primary" ><b>Registrar Ponto</b></button><br> 
                                        </a>
                                        </div>
                                        <!--div class='col-md-4'>
                                                <button style="width: 230px;background-color: #ff9a66;color: #14074f" type="button" class="btn btn-outline-primary" id="registrarPonto"><b>Registrar Ponto Facial</b></button><br>
                                        </div-->
                                    </div>
                                    <div class='row'>
                                        <div class='col-md-2'>
                                        </div>
                                        <div class='col-md-8'>
                                            <img alt="" style="width: 100px;" src="/assets/img/novoRegistro.png"><br>
                                            <span style="font-size: 12px;color: #14074f;"><b>Caso ainda não tenha se registrado. Clique em "Novo Registro" e siga o passo a passo para registrar-se.</b></span><br>
                                            <button  style="width: 180px;background-color: #14074f;color: #ff9a66" type="button" class="btn btn-outline-primary" id="novoRegistro"><b>Novo Registro</b></button>
                                        </div>
                                    </div>
                                    <br>

                                    <div class="row">
                                        <div class="col-md-4">
                                            &nbsp;
                                        </div>
                                        <div class="col-md-8" align="center">

                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
{% endblock %}